# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# AI agent skills (not project source)
/.agents/
/.kiro/
/.qoder/
/.skills/
/skills-lock.json

# testing
/coverage

